#!/usr/bin/env zsh
set -euo pipefail

# mac/install links this Mac to the Mac-frozen snapshot under ./mac.
# Keep Linux/Arch config work out of the live macOS dotfiles.
MAC="${0:A:h}"
GRAL="${MAC:h}"
link_managed_path() {
    local source="$1"
    local target="$2"

    mkdir -p "$(dirname "$target")"

    if [ -e "$target" ] && [ ! -L "$target" ]; then
        mv "$target" "$target.backup.$(date +%Y%m%d%H%M%S)"
    fi

    ln -sfn "$source" "$target"
}

configure_neural_keyboard_repeat() {
    # macOS repeat units are ~15 ms ticks:
    # InitialKeyRepeat=10 ~= 150 ms before repeat starts.
    # KeyRepeat=1 ~= 15 ms between repeats, the practical fastest setting.
    defaults write -g ApplePressAndHoldEnabled -bool false
    defaults write -g InitialKeyRepeat -int 10
    defaults write -g KeyRepeat -int 1
}

# Shell / terminal session.
link_managed_path "$MAC/zshrc" "$HOME/.zshrc"
link_managed_path "$MAC/tmux.conf" "$HOME/.tmux.conf"
link_managed_path "$MAC/custom.zsh-theme" "$HOME/.oh-my-zsh/custom/themes/custom.zsh-theme"

# macOS/X11 legacy pieces that are currently linked on this Mac.
link_managed_path "$MAC/xinitrc" "$HOME/.xinitrc"
link_managed_path "$MAC/xmodmap.sh" "$HOME/.xmodmap.sh"
link_managed_path "$MAC/xmodmap.conf" "$HOME/.xmodmap.conf"

# Vim fallback.
link_managed_path "$GRAL/nvim/vimrc" "$HOME/.vimrc"

# Neovim frozen for macOS.
link_managed_path "$MAC/nvim" "$HOME/.config/nvim"

# Yazi file manager.
link_managed_path "$MAC/yazi/yazi.toml" "$HOME/.config/yazi/yazi.toml"
link_managed_path "$MAC/yazi/keymap.toml" "$HOME/.config/yazi/keymap.toml"
link_managed_path "$MAC/yazi/theme.toml" "$HOME/.config/yazi/theme.toml"

# lf file manager: match the links currently active on this Mac.
link_managed_path "$GRAL/lf/lfrc" "$HOME/.config/lf/lfrc"
link_managed_path "$GRAL/lf/preview.sh" "$HOME/.config/lf/preview.sh"
link_managed_path "$GRAL/lf/pv.sh" "$HOME/.config/lf/pv.sh"

# Legacy desktop configs currently linked on this Mac.
link_managed_path "$MAC/i3.conf" "$HOME/.config/i3/config"
link_managed_path "$MAC/alacritty.yml" "$HOME/.config/alacritty/alacritty.yml"

# Claude/Codex AI agents, skills, hooks, rules, and shared instructions.
"$GRAL/sync-ai"

# System feel: wired-mechanical-keyboard, editor-first latency.
configure_neural_keyboard_repeat

cat <<'MSG'
Linked macOS dotfiles from ./mac.
Mac-frozen links point to ./mac; nvim/vimrc, lf, claude, and codex remain shared from repo root.
macOS keyboard repeat set to neural-direct mode:
  ApplePressAndHoldEnabled=false
  InitialKeyRepeat=10
  KeyRepeat=1
MSG
