#!/usr/bin/env zsh
set -euo pipefail

GRAL="${0:A:h}"

link_managed_path() {
    local source="$1"
    local target="$2"

    mkdir -p "$(dirname "$target")"

    if [ -e "$target" ] && [ ! -L "$target" ]; then
        mv "$target" "$target.backup.$(date +%Y%m%d%H%M%S)"
    fi

    ln -sfn "$source" "$target"
}

sync_claude() {
    # agent-memory and project memory are machine-local working state.
    link_managed_path "$GRAL/claude/settings.json" "$HOME/.claude/settings.json"
    link_managed_path "$GRAL/claude/CLAUDE.md" "$HOME/.claude/CLAUDE.md"
    link_managed_path "$GRAL/claude/agents" "$HOME/.claude/agents"
    link_managed_path "$GRAL/claude/skills" "$HOME/.claude/skills"
    link_managed_path "$GRAL/claude/commands" "$HOME/.claude/commands"
}

sync_codex() {
    mkdir -p "$HOME/.codex/rules"
    mkdir -p "$HOME/.codex/skills"

    link_managed_path "$GRAL/codex/config.toml" "$HOME/.codex/config.toml"
    link_managed_path "$GRAL/codex/hooks.json" "$HOME/.codex/hooks.json"
    link_managed_path "$GRAL/codex/rules/default.rules" "$HOME/.codex/rules/default.rules"
    link_managed_path "$GRAL/claude/CLAUDE.md" "$HOME/.codex/AGENTS.md"
    link_managed_path "$GRAL/claude/agents" "$HOME/.codex/agents"
    link_managed_path "$GRAL/claude/commands" "$HOME/.codex/commands"

    for skill in "$GRAL"/claude/skills/*; do
        [ -d "$skill" ] || continue
        link_managed_path "$skill" "$HOME/.codex/skills/${skill:t}"
    done
}

sync_claude
sync_codex

echo "Synced Claude and Codex AI config."
