# gral single-workspace: Foot/tmux + Chrome only.
set $mod Mod4
set $term foot -e tmux new-session -A -s work
set $browser google-chrome-stable --ozone-platform=wayland
font pango:JetBrainsMono Nerd Font 10

# Gruvbox dark medium: same palette as Foot and nvim gruvbox.nvim.
set $bg #282828
set $fg #ebdbb2
set $black #282828
set $red #cc241d
set $green #98971a
set $yellow #d79921
set $blue #458588
set $purple #b16286
set $aqua #689d6a
set $gray #a89984
set $darkgray #3c3836
set $inactive #928374

# Environment for DBus/session detection/input method.
exec systemctl --user import-environment WAYLAND_DISPLAY SWAYSOCK XDG_CURRENT_DESKTOP XDG_SESSION_DESKTOP XDG_SESSION_TYPE
exec dbus-update-activation-environment --systemd WAYLAND_DISPLAY SWAYSOCK XDG_CURRENT_DESKTOP XDG_SESSION_DESKTOP XDG_SESSION_TYPE
exec fcitx5 -d
exec mako

# Auto-start the two-window workbench.
exec $term
exec $browser

input * {
    xkb_layout us
    repeat_delay 300
    repeat_rate 30
}

# Floating two-window layout. Tune pixel sizes/positions after checking your real monitor size.
floating_modifier $mod normal
default_border pixel 1
default_floating_border pixel 1
client.focused $gray $gray $black $fg $gray
client.focused_inactive $darkgray $bg $gray $fg $darkgray
client.unfocused $black $black $gray $fg $black
client.urgent $red $red $fg $fg $red
for_window [app_id="foot"] floating enable, resize set width 1400 px height 950 px, move position 120 90
for_window [app_id="google-chrome"] floating enable, resize set width 1500 px height 980 px, move position 520 180
for_window [class="Google-chrome"] floating enable, resize set width 1500 px height 980 px, move position 520 180

# App-level controls live on Mod. Ctrl stays available for tmux/editor/browser content.
bindsym $mod+Tab focus next
bindsym $mod+Shift+Tab focus prev
bindsym $mod+Shift+t exec $term
bindsym $mod+Shift+g exec $browser
bindsym $mod+f fullscreen toggle
bindsym $mod+space floating toggle
bindsym $mod+q kill
bindsym $mod+r reload
bindsym $mod+Shift+q exit
bindsym $mod+Shift+s exec sh -c 'mkdir -p "$HOME/Pictures/Screenshots"; grim -g "$(slurp)" "$HOME/Pictures/Screenshots/$(date +%Y%m%d-%H%M%S).png"'

# Local Whisper dictation: Ctrl+F starts recording; Ctrl+F again stops, transcribes, and copies text.
bindsym Control+f exec $HOME/.local/bin/whisper-dictation-toggle

# Useful legacy WM muscle memory, translated to Sway/Mod and kept off Ctrl.
bindsym $mod+h focus left
bindsym $mod+j focus down
bindsym $mod+k focus up
bindsym $mod+l focus right
bindsym $mod+Shift+h move left
bindsym $mod+Shift+j move down
bindsym $mod+Shift+k move up
bindsym $mod+Shift+l move right
mode "resize" {
    bindsym h resize shrink width 5 px or 5 ppt
    bindsym j resize grow height 5 px or 5 ppt
    bindsym k resize shrink height 5 px or 5 ppt
    bindsym l resize grow width 5 px or 5 ppt
    bindsym Return mode "default"
    bindsym Escape mode "default"
    bindsym $mod+Shift+r mode "default"
}
bindsym $mod+Shift+r mode "resize"

# Hardware keys: transient Mako notifications, persistent status belongs in tmux.
bindsym XF86AudioRaiseVolume exec sh -c 'pamixer -i 5; notify-send -a audio -r 1001 -h int:value:"$(pamixer --get-volume)" "Volume" "$(pamixer --get-volume)%"'
bindsym XF86AudioLowerVolume exec sh -c 'pamixer -d 5; notify-send -a audio -r 1001 -h int:value:"$(pamixer --get-volume)" "Volume" "$(pamixer --get-volume)%"'
bindsym XF86AudioMute exec sh -c 'pamixer -t; if pamixer --get-mute | grep -q true; then notify-send -a audio -r 1001 "Volume" "Muted"; else notify-send -a audio -r 1001 -h int:value:"$(pamixer --get-volume)" "Volume" "Unmuted $(pamixer --get-volume)%"; fi'
bindsym XF86AudioMicMute exec sh -c 'pamixer --default-source -t; if pamixer --default-source --get-mute | grep -q true; then notify-send -a microphone -r 1003 "Mic" "Muted"; else notify-send -a microphone -r 1003 "Mic" "Unmuted"; fi'
bindsym XF86MonBrightnessUp exec sh -c 'brightnessctl set +5%; value="$(brightnessctl -m | cut -d, -f4 | tr -d %)"; notify-send -a brightness -r 1002 -h int:value:"$value" "Brightness" "$value%"'
bindsym XF86MonBrightnessDown exec sh -c 'brightnessctl set 5%-; value="$(brightnessctl -m | cut -d, -f4 | tr -d %)"; notify-send -a brightness -r 1002 -h int:value:"$value" "Brightness" "$value%"'

# No desktop menubar/workspace UI. Status lives in tmux; Sway stays invisible.
bar {
    mode invisible
}
