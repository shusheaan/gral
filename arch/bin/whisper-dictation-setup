#!/usr/bin/env zsh
set -euo pipefail

model="${WHISPER_MODEL:-large-v3}"
default_venv_dir="$HOME/.local/share/gral-whisper/.venv"
venv_dir="${WHISPER_VENV:-}"

for cmd in ffmpeg pw-record wl-copy notify-send; do
    if ! command -v "$cmd" >/dev/null 2>&1; then
        echo "missing command: $cmd" >&2
        exit 1
    fi
done

system_python_ready() {
    command -v python >/dev/null 2>&1 || return 1
    python - <<'PY' >/dev/null 2>&1
import torch
import whisper
PY
}

prefetch_model() {
    local python_bin="$1"

    "$python_bin" - <<'PY'
import torch
print("torch_cuda_available=", torch.cuda.is_available())
if torch.cuda.is_available():
    print("torch_cuda_device=", torch.cuda.get_device_name(0))
PY

    WHISPER_MODEL="$model" "$python_bin" - <<'PY'
import os
import torch
import whisper
model_name = os.environ.get("WHISPER_MODEL", "large-v3")
device = "cuda" if torch.cuda.is_available() else "cpu"
print(f"loading_model={model_name} device={device}")
whisper.load_model(model_name, device=device)
print("ready")
PY
}

if [ -z "$venv_dir" ] && system_python_ready; then
    echo "Using system Python for Whisper; no venv needed."
    prefetch_model "$(command -v python)"
    exit 0
fi

if ! command -v uv >/dev/null 2>&1; then
    echo "missing command: uv" >&2
    exit 1
fi

if [ -z "$venv_dir" ]; then
    venv_dir="$default_venv_dir"
fi
python_bin="$venv_dir/bin/python"

mkdir -p "${venv_dir:h}"
if [ ! -x "$python_bin" ]; then
    venv_args=()
    if [ "${WHISPER_SYSTEM_SITE:-0}" = "1" ]; then
        venv_args+=(--system-site-packages)
    fi
    uv venv "${venv_args[@]}" "$venv_dir"
fi

if ! "$python_bin" - <<'PY' >/dev/null 2>&1
import torch
import whisper
PY
then
    uv pip install --python "$python_bin" -U openai-whisper
fi

prefetch_model "$python_bin"
