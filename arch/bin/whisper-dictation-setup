#!/usr/bin/env zsh
set -euo pipefail

venv_dir="${WHISPER_VENV:-$HOME/.local/share/gral-whisper/.venv}"
model="${WHISPER_MODEL:-large-v3}"
python_bin="$venv_dir/bin/python"

for cmd in uv ffmpeg pw-record wl-copy notify-send; do
    if ! command -v "$cmd" >/dev/null 2>&1; then
        echo "missing command: $cmd" >&2
        exit 1
    fi
done

mkdir -p "${venv_dir:h}"
if [ ! -x "$python_bin" ]; then
    venv_args=()
    if [ "${WHISPER_SYSTEM_SITE:-0}" = "1" ]; then
        venv_args+=(--system-site-packages)
    fi
    uv venv "${venv_args[@]}" "$venv_dir"
fi

# For NVIDIA/ROCm, install the matching torch wheel first if needed, then rerun this.
# Example pattern after checking the official PyTorch selector:
#   uv pip install --python "$python_bin" torch --index-url <pytorch-wheel-index>
if ! "$python_bin" - <<'PY' >/dev/null 2>&1
import torch
import whisper
PY
then
    uv pip install --python "$python_bin" -U openai-whisper
fi

"$python_bin" - <<PY
import torch
print("torch_cuda_available=", torch.cuda.is_available())
if torch.cuda.is_available():
    print("torch_cuda_device=", torch.cuda.get_device_name(0))
PY

# Pre-download the model so the first Ctrl+F transcription does not block on download.
WHISPER_MODEL="$model" "$python_bin" - <<'PY'
import os
import torch
import whisper
model_name = os.environ.get("WHISPER_MODEL", "large-v3")
device = "cuda" if torch.cuda.is_available() else "cpu"
print(f"loading_model={model_name} device={device}")
whisper.load_model(model_name, device=device)
print("ready")
PY
