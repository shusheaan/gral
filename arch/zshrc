# Arch Linux zsh config managed by ~/work/gral/arch.

# Prompt / colors: same compact sammy-style prompt as mac/zshrc, without Oh My Zsh.
autoload -U colors && colors
setopt prompt_subst

sammy_git_prompt() {
  command git rev-parse --is-inside-work-tree >/dev/null 2>&1 || return 0

  local branch
  branch="$(command git symbolic-ref --quiet --short HEAD 2>/dev/null || command git rev-parse --short HEAD 2>/dev/null)" || return 0

  printf "(%s)" "$branch"
}

PS1='%{$fg[white]%}%c$(sammy_git_prompt)$ %{$reset_color%}'

# Completion.
if [ -d /usr/share/zsh/site-functions ]; then
  fpath=(/usr/share/zsh/site-functions $fpath)
fi

autoload -U compinit promptinit
zstyle ':completion:*' matcher-list 'm:{a-zA-Z}={A-Za-z}' 'r:|=*' 'l:|=* r:|=*'
zstyle ':completion:*' menu select
zmodload zsh/complist
compinit
_comp_options+=(globdots)

# Vi mode.
bindkey -v
export KEYTIMEOUT=1
bindkey -M menuselect 'h' vi-backward-char
bindkey -M menuselect 'j' vi-down-line-or-history
bindkey -M menuselect 'k' vi-up-line-or-history
bindkey -M menuselect 'l' vi-forward-char
bindkey -v '^?' backward-delete-char

# Basic environment.
export LANG=en_US.UTF-8
export EDITOR=nvim
export VISUAL=nvim
if [ -z "${TERM:-}" ]; then
  export TERM=xterm-256color
fi
export PATH="$HOME/.local/bin:$HOME/.cargo/bin:$PATH"
export RUST_BACKTRACE=full

# Python cache hygiene.
export MYPY_CACHE_DIR="$HOME/.cache/mypy"
export PYTHONPYCACHEPREFIX="$HOME/.cache/pycache"
export RUFF_CACHE_DIR="$HOME/.cache/ruff"

# Bare zsh baseline: no Oh My Zsh or plugin manager in the first Arch version.
# Lightweight plugins are loaded directly from Arch packages; no Oh My Zsh required.
if [ -r /usr/share/zsh/plugins/zsh-autosuggestions/zsh-autosuggestions.zsh ]; then
  ZSH_AUTOSUGGEST_HIGHLIGHT_STYLE='fg=8'
  source /usr/share/zsh/plugins/zsh-autosuggestions/zsh-autosuggestions.zsh
fi

# Auto attach tmux only for SSH sessions.
if command -v tmux >/dev/null 2>&1; then
  if [ -n "${SSH_CONNECTION:-}" ] && [ -z "${TMUX:-}" ] && [ -t 1 ]; then
    exec tmux new-session -A -s work
  fi
fi

# System / desktop.
alias yo='sudo pacman -Syu'
alias refresh='source ~/.zshrc'
alias gc='chromium'
alias bt='bluetoothctl'
alias mute='pamixer -t'
alias unmute='pamixer --unmute'
alias vol='pamixer --get-volume'
alias citrix='/opt/Citrix/ICAClient/wfica'

exitsway() {
  if command -v swaymsg >/dev/null 2>&1 && swaymsg exit 2>/dev/null; then
    return 0
  fi

  local socket
  socket="$(ls /run/user/"$UID"/sway-ipc.*.sock 2>/dev/null | head -n 1)"
  if [ -z "$socket" ]; then
    echo "No Sway IPC socket found under /run/user/$UID." >&2
    return 1
  fi

  SWAYSOCK="$socket" swaymsg exit
}

# Start Sway as the whole local login session.
# Because this uses `exec`, Mod+Shift+Q exits Sway back to the TTY login prompt,
# not to an already-unlocked shell. The tmux server stays detached.
sway() {
  if [ -n "${SSH_CONNECTION:-}" ]; then
    echo "Refusing to start Sway from SSH." >&2
    return 1
  fi

  if [ -n "${TMUX:-}" ]; then
    echo "Start Sway from the bare TTY login shell, not inside tmux." >&2
    return 1
  fi

  if [ ! -x /usr/bin/sway ]; then
    echo "sway is not installed at /usr/bin/sway" >&2
    return 1
  fi

  # Arch GUI baseline is NVIDIA-first; always pass wlroots' explicit opt-in.
  exec /usr/bin/sway --unsupported-gpu "$@"
}

# tmux.
alias tls='tmux ls'
alias tatt='tmux attach -t'
alias tdet='tmux detach -t'
alias ttk='tmux kill-server'
alias ttr='tmux resize-pane -R 20'
alias ttl='tmux resize-pane -L 20'

_tnew_attach() {
  if [ -n "${TMUX:-}" ]; then
    tmux switch-client -t "=$1"
  else
    tmux attach-session -t "=$1"
  fi
}

tnew() {
  if [ $# -ne 1 ]; then
    echo "usage: tnew <session>" >&2
    return 2
  fi

  local session="$1"
  local -a size_args
  local width="${COLUMNS:-}"
  local height="${LINES:-}"

  size_args=()

  if [ -n "${TMUX:-}" ]; then
    width="$(tmux display-message -p '#{client_width}')" || return
    height="$(tmux display-message -p '#{client_height}')" || return
  fi

  if [[ "$width" = <-> && "$height" = <-> ]]; then
    size_args=(-x "$width" -y "$height")
  fi

  if tmux has-session -t "=$session" 2>/dev/null; then
    _tnew_attach "$session"
    return
  fi

  tmux new-session -d -s "$session" "${size_args[@]}" || return
  _tnew_attach "$session"
}

# lf: cd to last directory after quitting.
lfcd () {
    local tmp
    tmp="$(mktemp)"
    lf -last-dir-path="$tmp" "$@"
    if [ -f "$tmp" ]; then
        local dir
        dir="$(cat "$tmp")"
        rm -f "$tmp"
        if [ -d "$dir" ] && [ "$dir" != "$(pwd)" ]; then
            cd "$dir"
        fi
    fi
}
alias lf=lfcd

# Development shortcuts.
alias ct='cargo test -- --nocapture'
alias cb='cargo build && rust-gdb "$PWD/target/debug/$(basename "$PWD")" --silent'
alias jl='julia --project=.'
alias cm='cmatrix -C cyan'
alias cc='claude'
alias ca='claude agents'

# Node/Bun optional setup.
export NVM_DIR="$HOME/.nvm"
[ -s "$NVM_DIR/nvm.sh" ] && . "$NVM_DIR/nvm.sh"
[ -s "$NVM_DIR/bash_completion" ] && . "$NVM_DIR/bash_completion"
export BUN_INSTALL="$HOME/.bun"
export PATH="$BUN_INSTALL/bin:$PATH"

# Git shortcuts.
alias ga='git add -A'
alias gm='git commit -m'
alias gp='git push origin'
alias gs='git status'

# zsh-syntax-highlighting should be sourced near the end of .zshrc.
if [ -r /usr/share/zsh/plugins/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh ]; then
  source /usr/share/zsh/plugins/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh
fi
