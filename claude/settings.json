{
  "permissions": {
    "allow": [
      "Bash(python -m mypy tests/test_sim.py --ignore-missing-imports)",
      "Bash(python3 -m mypy tests/test_sim.py --ignore-missing-imports)",
      "Bash(uv run:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git push:*)"
    ],
    "defaultMode": "auto"
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": []
      },
      {
        "matcher": "Grep|Glob|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node \"/Users/shu/.claude/hooks/gitnexus/gitnexus-hook.cjs\"",
            "timeout": 10,
            "statusMessage": "Enriching with GitNexus graph context..."
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "permission_prompt|elicitation_dialog",
        "hooks": [
          {
            "type": "command",
            "command": "workmux set-window-status waiting"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "workmux set-window-status working"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node \"/Users/shu/.claude/hooks/gitnexus/gitnexus-hook.cjs\"",
            "timeout": 10,
            "statusMessage": "Checking GitNexus index freshness..."
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "workmux set-window-status done"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "workmux set-window-status working"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "/Users/shu/GitHub/gral/claude/statusline.py",
    "padding": 0,
    "refreshInterval": 5
  },
  "enabledPlugins": {
    "rust-analyzer-lsp@claude-plugins-official": true,
    "superpowers@claude-plugins-official": true,
    "document-skills@anthropic-agent-skills": true,
    "financial-analysis@claude-for-financial-services": true,
    "equity-research@claude-for-financial-services": true,
    "wealth-management@claude-for-financial-services": true,
    "market-researcher@claude-for-financial-services": true
  },
  "extraKnownMarketplaces": {
    "anthropic-agent-skills": {
      "source": {
        "source": "github",
        "repo": "anthropics/skills"
      }
    },
    "claude-for-financial-services": {
      "source": {
        "source": "git",
        "url": "https://github.com/anthropics/financial-services.git"
      }
    }
  },
  "sandbox": {
    "enabled": true,
    "failIfUnavailable": true,
    "autoAllowBashIfSandboxed": true,
    "allowUnsandboxedCommands": false
  },
  "effortLevel": "xhigh",
  "autoCompactWindow": 500000,
  "skipDangerousModePermissionPrompt": true,
  "autoCompactEnabled": true,
  "skipAutoPermissionPrompt": true,
  "defaultMode": "acceptEdits",
  "disableBypassPermissionsMode": "disable"
}
